# Copy to .env for local runs (the workflow uses GitHub Secrets, not this file).
# All are optional — the scraper runs without them, just with reduced features.

# Where new intern/new-grad US jobs get announced. Without it, they print to stdout.
DISCORD_WEBHOOK_URL=

# Apps Script web-app URL for the Google Sheet sync (setup: docs/apps_script.gs).
GOOGLE_SHEETS_WEBHOOK_URL=

# Residential proxy for Glassdoor/ZipRecruiter, which block datacenter IPs.
# Only proxy-required sites are routed through it; Indeed always goes direct.
# Format: http://user:pass@host:port  or  socks5://user:pass@host:port
JOBSPY_PROXY=
